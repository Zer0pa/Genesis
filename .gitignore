# No artifacts/ at repo root yet (will be populated as receipts pull from phone).
# Keep it; do not ignore.

# macOS
.DS_Store

# Python
__pycache__/
*.pyc

# Editor temporaries
*.swp
*.bak

# Rust build artifacts
target/

# GPD state backup
.gpd/state.json.bak

# Planning / session scratch (not research artifacts)
_planning/
_session/

# Node (if any tooling is added)
node_modules/

# Cargo cache (local mirror; large, not needed in repo)
.cargo/registry/
.cargo/git/

# Harness phone-side logs (receipts are JSON; raw logs are ephemeral)
harness/phone/*.log

# Receipt working-directory leftovers (per-iter intermediate artifacts; not proofs)
proofs/artifacts/cells/*/*/wd/

# BITDET_5K stdout.log: 15MB per instance × 6 = 90MB of repeated pipeline dump.
# Receipt JSON + canonical_stdout.sha256 carry the determinism evidence; the
# stdout.log is ephemeral. Keep all other cells' stdout.log (smaller, contains
# KPI lines for σ″-curve extraction).
proofs/artifacts/cells/BITDET_5K/*/stdout.log
